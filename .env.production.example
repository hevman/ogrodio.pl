# ─── Produkcja Ogrodio — skopiuj do .env i uzupełnij ────────────────────────
# docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env up -d --build

# ─── Repozytorium ───────────────────────────────────────────────────────────
# https://github.com/hevman/ogrodio.pl
OGRODIO_REPO_URL=https://github.com/hevman/ogrodio.pl.git
OGRODIO_INSTALL_DIR=/opt/ogrodio/app

COMPOSE_PROJECT_NAME=ogrodio

# ─── Sekrety (wygeneruj: openssl rand -base64 32) ───────────────────────────
GARDEN_JWT_SECRET=
VENDURE_COOKIE_SECRET=
MEILISEARCH_MASTER_KEY=
DIGEST_CRON_SECRET=

# ─── Bazy PostgreSQL ────────────────────────────────────────────────────────
BACKEND_POSTGRES_USER=garden
BACKEND_POSTGRES_PASSWORD=
BACKEND_POSTGRES_DB=garden_backend

COMMERCE_POSTGRES_USER=vendure
COMMERCE_POSTGRES_PASSWORD=
COMMERCE_POSTGRES_DB=vendure

# ─── Vendure admin ──────────────────────────────────────────────────────────
VENDURE_SUPERADMIN_USERNAME=
VENDURE_SUPERADMIN_PASSWORD=
VENDURE_ADMIN_TOKEN=

# Vendure: true na pierwszy deploy (brak migracji w repo); potem false + migracje
DB_SYNCHRONIZE=true

# ─── Domeny (HTTPS) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ogrodio.pl
NEXT_PUBLIC_SHOP_URL=https://sklep.ogrodio.pl
NEXT_PUBLIC_APP_URL=https://app.ogrodio.pl
NEXT_PUBLIC_PANEL_URL=https://panel.ogrodio.pl
APP_PUBLIC_URL=https://app.ogrodio.pl
ASSET_URL_PREFIX=https://sklep.ogrodio.pl/assets/
AUTH_COOKIE_DOMAIN=.ogrodio.pl

# ─── E-mail (digest tygodniowy, powiadomienia) ──────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Ogrodio <noreply@ogrodio.pl>
SMTP_SECURE=true

# ─── Cloudflare SSL (zalecane) ──────────────────────────────────────────────
# Origin Certificate → deploy/ssl/cloudflare-origin.pem + cloudflare-origin.key
# Cloudflare: SSL/TLS → Full (strict). Instrukcja: deploy/CLOUDFLARE.md

# ─── Let's Encrypt (tylko bez Cloudflare proxy) ───────────────────────────────
# CERTBOT_EMAIL=kontakt@ogrodio.pl
# CERTBOT_DOMAIN=ogrodio.pl
