# ─── Sekrety (skopiuj do .env i zmień wartości) ──────────────────────────────

# NestJS Backend
GARDEN_JWT_SECRET=garden-zmien-mnie-na-silny-sekret-min-32-znaki

# Vendure
VENDURE_COOKIE_SECRET=vendure-cookie-secret-zmien
VENDURE_SUPERADMIN_USERNAME=superadmin
VENDURE_SUPERADMIN_PASSWORD=SuperAdmin123!

# Vendure Admin API Token (generuj po pierwszym uruchomieniu)
# docker exec garden-commerce-server npx vendure generate-api-token
VENDURE_ADMIN_TOKEN=

# Autopay - uzupelnij dopiero po aktywacji serwisu w portalu Autopay
AUTOPAY_ENABLED=false
AUTOPAY_SERVICE_ID=
AUTOPAY_HASH_KEY=
AUTOPAY_GATEWAY_URL=https://testpay.autopay.eu/
AUTOPAY_RETURN_URL=http://sklep.ogrodio.localhost/checkout/potwierdzenie
AUTOPAY_ITN_URL=http://sklep.ogrodio.localhost/shop-api/payments/autopay/itn

# Meilisearch
MEILISEARCH_MASTER_KEY=garden-meili-local-key
