{
  "name": "garden-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Ogrodio platform root command runner",
  "scripts": {
    "install:all": "npm --prefix frontend install && npm --prefix backend install && npm --prefix commerce install",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:commerce": "npm --prefix commerce run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:all": "npm run build:backend && npm run build:frontend && npm run build:commerce",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build:commerce": "npm --prefix commerce run build",
    "start:frontend": "npm --prefix frontend run start",
    "start:backend": "npm --prefix backend run start",
    "start:commerce": "npm --prefix commerce run start",
    "articles:images": "npm --prefix frontend run articles:images",
    "articles:import": "npm --prefix backend run import-articles",
    "articles:index": "npm --prefix backend run index-articles",
    "articles:sync-media": "npm --prefix backend run sync-article-media",
    "shop:seed": "npm --prefix commerce run seed:garden",
    "shop:index": "npm --prefix commerce run index:meili",
    "docker:up": "docker compose up -d",
    "docker:build": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.yml -f docker-compose.prod.yml down",
    "vps:install": "bash deploy/install-server.sh",
    "vps:deploy": "bash deploy/post-install.sh",
    "vps:status": "bash deploy/status.sh"
  }
}
